PORT=3000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/eyecare
JWT_SECRET=replace-with-a-strong-secret
# Optional: public URL of the deployed API (shown in logs + /health during local testing).
# Point your Expo app here with EXPO_PUBLIC_API_URL while the phone can’t reach localhost.
PUBLIC_API_URL=https://lensifyserver.onrender.com
# Use "*" to allow all origins during development.
# For production, use a comma-separated allow-list, e.g.:
# CORS_ORIGIN=https://your-app.com,https://staging.your-app.com
CORS_ORIGIN=*
